# -----------------------------------------------------------------------------
# Runtime Configuration
# -----------------------------------------------------------------------------
# Application mode: development | production
NODE_ENV=

# API server port
PORT=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# MongoDB connection URI
# Example:
# mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGODB_URI=

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Secret used to sign JWT tokens
# Generate a strong random value before production use
JWT_SECRET=

# -----------------------------------------------------------------------------
# Media Storage (Cloudinary)
# -----------------------------------------------------------------------------
# Credentials available from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# Frontend / Client URLs
# -----------------------------------------------------------------------------
# Base frontend URL
# Example: http://localhost:3000
FRONTEND_URL=

# URL used in password reset emails
# Example: http://localhost:3000/reset-password
RESET_PASSWORD_URL=

# Allowed CORS origin in production
ALLOWED_ORIGIN=

# -----------------------------------------------------------------------------
# Email Provider (Resend)
# -----------------------------------------------------------------------------
# API key used for transactional emails
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Payments (Stripe)
# -----------------------------------------------------------------------------
# Secret API key from Stripe dashboard
STRIPE_SECRET_KEY=

# Webhook signing secret for Stripe events
STRIPE_WEBHOOK_SECRET=